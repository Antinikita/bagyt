# Where the SPA looks for the Laravel API. The CSP plugin in
# vite.config.js bakes this origin into the production bundle's
# Content-Security-Policy meta tag at build time, so it must be set
# *before* `npm run build` (Vercel reads project env vars before the
# build command — set it in the dashboard for each environment).
VITE_API_URL=http://localhost:8000

# Sentry browser SDK DSN. Leave blank locally — Sentry.init is gated
# on this value being truthy in src/main.jsx.
VITE_SENTRY_DSN=
